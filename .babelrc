{
  "presets": [
    [
      "@babel/env", {
        "targets": {"node": "14"},
        // Leave import/export statements unchanged in the babel transpiling output.
        "modules": false
      }
    ]
  ],
  "plugins": [
    ["./scripts/babel-plugin-inline-environment-variables.cjs", {
      "include": [
        "WEBEXT_BUILD_ENV"
      ]
    }] 
  ],
  "env": {
    "test": {
      "plugins": [ "istanbul" ]
    }
  }
}
